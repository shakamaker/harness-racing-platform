# =============================================================================
# .env.example — copy to .env (which is gitignored) before running anything.
#   cp .env.example .env
# Never commit a populated .env. pre-commit + gitleaks should catch this but
# do not rely on tooling alone.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Application code uses the asyncpg driver (SQLAlchemy create_async_engine).
# Alembic and CI run with the sync psycopg driver. Both URLs point at the
# same database — keep them in lockstep when changing host/port/credentials.
DATABASE_URL=postgresql+asyncpg://harness:harness_dev@localhost:5432/harness
DATABASE_URL_SYNC=postgresql+psycopg://harness:harness_dev@localhost:5432/harness

# -----------------------------------------------------------------------------
# Scraper
# -----------------------------------------------------------------------------
SCRAPER_PROXY_URL=
SCRAPER_RATE_LIMIT_RPM=30
SCRAPER_WORKERS_PER_STATE=3
SCRAPER_USER_AGENT_POOL=firefox-desktop,chrome-desktop
RAW_HTML_DIR=./raw_html

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# Generate per-environment. Never commit a populated value.
API_KEY=

# Bind to loopback by default. Use 0.0.0.0 only inside a container with an
# explicit port mapping, or behind a reverse proxy. Binding to 0.0.0.0 on a
# dev laptop publishes the API to every host on the local network — including
# any guest device on a coffee-shop / hotel / co-working LAN.
API_HOST=127.0.0.1
API_PORT=8000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
